<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_50">

    <!-- Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:titleTextColor="@android:color/white"
            app:title="Notificaciones" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Contenido principal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Contador de no leídas -->
        <TextView
            android:id="@+id/tv_no_leidas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/danger"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_margin="16dp"
            android:visibility="gone"
            tools:text="No leídas (2)" />

        <!-- ✅ NUEVO - Filtros temporales -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_filtros"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_todas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋 Todas"
                    android:checked="true"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/chip_background_selector"
                    app:chipStrokeWidth="1dp"
                    app:chipStrokeColor="@color/primary"
                    android:textColor="@color/chip_text_color_selector"
                    android:textSize="14sp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_hoy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅 Hoy"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/chip_background_selector"
                    app:chipStrokeWidth="1dp"
                    app:chipStrokeColor="@color/primary"
                    android:textColor="@color/chip_text_color_selector"
                    android:textSize="14sp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_24h"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏰ 24h"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/chip_background_selector"
                    app:chipStrokeWidth="1dp"
                    app:chipStrokeColor="@color/primary"
                    android:textColor="@color/chip_text_color_selector"
                    android:textSize="14sp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_semana"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 Semana"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/chip_background_selector"
                    app:chipStrokeWidth="1dp"
                    app:chipStrokeColor="@color/primary"
                    android:textColor="@color/chip_text_color_selector"
                    android:textSize="14sp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_no_leidas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔴 No leídas"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/chip_background_selector"
                    app:chipStrokeWidth="1dp"
                    app:chipStrokeColor="@color/danger"
                    android:textColor="@color/chip_text_color_selector"
                    android:textSize="14sp" />

            </com.google.android.material.chip.ChipGroup>

        </HorizontalScrollView>

        <!-- SwipeRefreshLayout con RecyclerView -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipe_refresh"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_notificaciones"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingTop="8dp"
                android:paddingBottom="80dp" />

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/layout_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔔"
                android:textSize="64sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sin notificaciones"
                android:textColor="@color/gray_900"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cuando tengas nuevas tareas,\nrecordatorios o calificaciones,\naparecerán aquí"
                android:textColor="@color/gray_600"
                android:textSize="14sp"
                android:textAlignment="center" />

        </LinearLayout>

        <!-- Botón eliminar leídas -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_eliminar_leidas"
            style="@style/CustomTextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:text="🗑️ Eliminar todas las leídas"
            android:textColor="@color/gray_600"
            android:textSize="12sp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
