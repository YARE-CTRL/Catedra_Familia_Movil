<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_50"
    tools:context=".TareasActivity">

    <!-- AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        app:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:titleTextColor="@color/white"
            app:subtitleTextColor="#B3FFFFFF"
            app:navigationIcon="@drawable/ic_arrow_back" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Contenido -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Filtros con Chips -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:elevation="2dp">

            <!-- Filtros por Estado -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="8dp">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_filtros"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_todas"
                        style="@style/CustomChipStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Todas"
                        android:checked="true" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_pendientes"
                        style="@style/CustomChipStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pendientes" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_vencidas"
                        style="@style/CustomChipStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vencidas" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_completadas"
                        style="@style/CustomChipStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Completadas" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_calificadas"
                        style="@style/CustomChipStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calificadas" />

                </com.google.android.material.chip.ChipGroup>

            </HorizontalScrollView>

            <!-- Filtros por Fecha y Ordenamiento -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingBottom="12dp"
                android:gravity="center_vertical">

                <!-- Filtros por Fecha -->
                <HorizontalScrollView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:scrollbars="none">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_fecha"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_todos_tiempos"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="Todas"
                            android:textSize="12sp"
                            android:checked="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_hoy"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="📅 Hoy"
                            android:textSize="12sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_24h"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="⏰ 24h"
                            android:textSize="12sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_semana"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="📊 Semana"
                            android:textSize="12sp" />

                    </com.google.android.material.chip.ChipGroup>

                </HorizontalScrollView>

                <!-- Botón de Ordenamiento -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_ordenar"
                    style="@style/Widget.Material3.Button.TextButton.Icon"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Fecha ↓"
                    android:textSize="12sp"
                    android:textColor="@color/primary"
                    android:paddingHorizontal="12dp"
                    android:minWidth="0dp"
                    app:icon="@drawable/ic_sort"
                    app:iconSize="16dp"
                    app:iconTint="@color/primary" />

            </LinearLayout>

        </LinearLayout>

        <!-- SwipeRefreshLayout con RecyclerView -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipe_refresh"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_tareas"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp"
                android:clipToPadding="false"
                tools:listitem="@layout/item_tarea_card" />

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </LinearLayout>

    <!-- Estado vacío -->
    <LinearLayout
        android:id="@+id/ll_estado_vacio"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:padding="32dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_tasks"
            app:tint="@color/gray_300"
            android:contentDescription="Sin tareas" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="No hay tareas"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/gray_600" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Las tareas asignadas aparecerán aquí"
            android:textSize="14sp"
            android:textColor="@color/gray_600"
            android:textAlignment="center" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

