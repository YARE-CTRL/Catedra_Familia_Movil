    <color name="gray_600">#4B5563</color>          <!-- Textos secundarios -->
    <color name="gray_900">#111827</color>          <!-- Textos principales -->

    <!-- Offline mode -->
    <color name="offline_bg">#FEF3C7</color>        <!-- Banner offline (amarillo claro) -->
    <color name="offline_text">#92400E</color>      <!-- Texto offline -->

    <!-- ═══════════════════════════════════════════════════════════ -->
