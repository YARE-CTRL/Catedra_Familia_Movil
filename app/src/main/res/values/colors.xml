    <!-- ═══════════════════════════════════════════════════════════ -->

    <!-- Estados de tareas -->
    <color name="success">#1FA3A8</color>           <!-- Verde azulado - completadas -->
    <color name="warning">#F2C94C</color>           <!-- Amarillo dorado - próximas a vencer -->
